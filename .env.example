# Spotify API — Required for user login & playlist fetching
# Get your Client ID from https://developer.spotify.com/dashboard (create an app)
# This is public and safe to expose (OAuth PKCE flow needs it client-side)
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=

# Spotify OAuth Redirect URI — must match what you register in Spotify Dashboard
# For local dev: http://localhost:3000/api/spotify/callback
# For production: https://yourdomain.vercel.app/api/spotify/callback
NEXT_PUBLIC_SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# YouTube API — Required for YouTube search & audio playback
# Get from https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_YOUTUBE_API_KEY=

# Streaming Proxy (optional — for resolving YouTube audio streams)
NEXT_PUBLIC_STREAM_PROXY_URL=

# Socket.IO server URL (required for room/party features)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
